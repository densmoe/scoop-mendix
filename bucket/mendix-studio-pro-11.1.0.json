{
  "version": "11.1.0",
  "description": "Low-code application development platform",
  "homepage": "https://www.mendix.com/studio-pro/",
  "license": "Proprietary",
  "architecture": {
    "64bit": {
      "url": "https://artifacts.rnd.mendix.com/modelers/Mendix-11.1.0.75979-User-x64-Setup.exe",
      "hash": "6635019BCD449993B43229E558ACE5C427E4E3E0CDF5EAFC00387B35943AB0C1"
    },
    "arm64": {
      "url": "https://artifacts.rnd.mendix.com/modelers/Mendix-11.1.0.75979-User-arm64-Setup.exe",
      "hash": "F593A7AF38DAC4E1E1F65D6ED128928DF26F9208E86294251DAD37B1B931B4BF"
    }
  },
  "innosetup": true,
  "post_install": [
    "$installPath = \"$env:LOCALAPPDATA\\Programs\\Mendix\"",
    "$version = Get-ChildItem $installPath | Where-Object { $_.Name -like '11.1.0*' } | Select-Object -First 1 -ExpandProperty Name",
    "$exePath = \"$installPath\\$version\\modeler\\Mendix.exe\"",
    "if (Test-Path $exePath) {",
    "  New-Item -ItemType SymbolicLink -Path \"$dir\\Mendix.exe\" -Target $exePath -Force | Out-Null",
    "} else {",
    "  Write-Host \"Warning: Mendix executable not found at $exePath\" -ForegroundColor Yellow",
    "}"
  ],
  "bin": "Mendix.exe",
  "shortcuts": [
    [
      "Mendix.exe",
      "Mendix Studio Pro 11.1.0"
    ]
  ],
  "uninstaller": {
    "script": "Get-ItemProperty 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*' | Where-Object { $_.DisplayName -like '*Mendix*11.1.0*' } | ForEach-Object { Start-Process -Wait ($_.UninstallString -replace '\"','') -ArgumentList '/VERYSILENT' }"
  },
  "checkver": {
    "url": "https://marketplace.mendix.com/link/studiopro/",
    "jsonpath": "$.version"
  },
  "notes": "Mendix Studio Pro installs to %LOCALAPPDATA%\\Programs\\Mendix\\<version>. Multiple versions can coexist."
}
