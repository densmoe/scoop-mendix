{
  "version": "10.16.1",
  "description": "Low-code application development platform",
  "homepage": "https://www.mendix.com/studio-pro/",
  "license": "Proprietary",
  "architecture": {
    "64bit": {
      "url": "https://artifacts.rnd.mendix.com/modelers/Mendix-10.16.1.50808-User-x64-Setup.exe",
      "hash": "DA587B597456848F2E7AA788D89388DFE4FC1FCCC13B913C1BBC4206B41FE8B5"
    },
    "arm64": {
      "url": "https://artifacts.rnd.mendix.com/modelers/Mendix-10.16.1.50808-User-arm64-Setup.exe",
      "hash": "0300E783096B3A0675BEAC03F3B14CB19D0FBF2DBF29F184C13F6A7FC8FCA744"
    }
  },
  "innosetup": true,
  "post_install": [
    "$installPath = \"$env:LOCALAPPDATA\\Programs\\Mendix\"",
    "$version = Get-ChildItem $installPath | Where-Object { $_.Name -like '10.16.1*' } | Select-Object -First 1 -ExpandProperty Name",
    "$exePath = \"$installPath\\$version\\modeler\\Mendix.exe\"",
    "if (Test-Path $exePath) {",
    "  New-Item -ItemType SymbolicLink -Path \"$dir\\Mendix.exe\" -Target $exePath -Force | Out-Null",
    "} else {",
    "  Write-Host \"Warning: Mendix executable not found at $exePath\" -ForegroundColor Yellow",
    "}"
  ],
  "bin": "Mendix.exe",
  "shortcuts": [
    [
      "Mendix.exe",
      "Mendix Studio Pro 10.16.1"
    ]
  ],
  "uninstaller": {
    "script": "Get-ItemProperty 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*' | Where-Object { $_.DisplayName -like '*Mendix*10.16.1*' } | ForEach-Object { Start-Process -Wait ($_.UninstallString -replace '\"','') -ArgumentList '/VERYSILENT' }"
  },
  "checkver": {
    "url": "https://marketplace.mendix.com/link/studiopro/",
    "jsonpath": "$.version"
  },
  "notes": "Mendix Studio Pro installs to %LOCALAPPDATA%\\Programs\\Mendix\\<version>. Multiple versions can coexist."
}
