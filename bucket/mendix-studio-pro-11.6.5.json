{
  "version": "11.6.5",
  "description": "Low-code application development platform",
  "homepage": "https://www.mendix.com/studio-pro/",
  "license": "Proprietary",
  "architecture": {
    "64bit": {
      "url": "https://artifacts.rnd.mendix.com/modelers/Mendix-11.6.5-User-x64-Setup.exe",
      "hash": "9892AE8F4292E5FADE920A9CE74605FA7F2C537840F2125F6F9600BEDA88EFD2"
    },
    "arm64": {
      "url": "https://artifacts.rnd.mendix.com/modelers/Mendix-11.6.5-User-arm64-Setup.exe",
      "hash": "9325C82D6A6640910184EFD598E260CB2D0DDEAC338ECB574BB60F1C3D72F0B8"
    }
  },
  "innosetup": true,
  "post_install": [
    "$installPath = \"$env:LOCALAPPDATA\\Programs\\Mendix\"",
    "$version = Get-ChildItem $installPath | Where-Object { $_.Name -like '11.6.5*' } | Select-Object -First 1 -ExpandProperty Name",
    "$exePath = \"$installPath\\$version\\modeler\\Mendix.exe\"",
    "if (Test-Path $exePath) {",
    "  New-Item -ItemType SymbolicLink -Path \"$dir\\Mendix.exe\" -Target $exePath -Force | Out-Null",
    "} else {",
    "  Write-Host \"Warning: Mendix executable not found at $exePath\" -ForegroundColor Yellow",
    "}"
  ],
  "bin": "Mendix.exe",
  "shortcuts": [
    [
      "Mendix.exe",
      "Mendix Studio Pro 11.6.5"
    ]
  ],
  "uninstaller": {
    "script": "Get-ItemProperty 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*' | Where-Object { $_.DisplayName -like '*Mendix*11.6.5*' } | ForEach-Object { Start-Process -Wait ($_.UninstallString -replace '\"','') -ArgumentList '/VERYSILENT' }"
  },
  "checkver": {
    "url": "https://marketplace.mendix.com/link/studiopro/",
    "jsonpath": "$.version"
  },
  "notes": "Mendix Studio Pro installs to %LOCALAPPDATA%\\Programs\\Mendix\\<version>. Multiple versions can coexist."
}
