{
  "version": "10.18.4",
  "description": "Low-code application development platform",
  "homepage": "https://www.mendix.com/studio-pro/",
  "license": "Proprietary",
  "architecture": {
    "64bit": {
      "url": "https://artifacts.rnd.mendix.com/modelers/Mendix-10.18.4.61760-User-x64-Setup.exe",
      "hash": "A80507037DB9673AD4CD1ECFFCA4766D23B4DE141BAAB700924FBCCBAD68A62F"
    },
    "arm64": {
      "url": "https://artifacts.rnd.mendix.com/modelers/Mendix-10.18.4.61760-User-arm64-Setup.exe",
      "hash": "30EDC63F9E53488E796115FF07501D7C85E5283809CF8D03193C7D286756E52B"
    }
  },
  "innosetup": true,
  "post_install": [
    "$installPath = \"$env:LOCALAPPDATA\\Programs\\Mendix\"",
    "$version = Get-ChildItem $installPath | Where-Object { $_.Name -like '10.18.4*' } | Select-Object -First 1 -ExpandProperty Name",
    "$exePath = \"$installPath\\$version\\modeler\\Mendix.exe\"",
    "if (Test-Path $exePath) {",
    "  New-Item -ItemType SymbolicLink -Path \"$dir\\Mendix.exe\" -Target $exePath -Force | Out-Null",
    "} else {",
    "  Write-Host \"Warning: Mendix executable not found at $exePath\" -ForegroundColor Yellow",
    "}"
  ],
  "bin": "Mendix.exe",
  "shortcuts": [
    [
      "Mendix.exe",
      "Mendix Studio Pro 10.18.4"
    ]
  ],
  "uninstaller": {
    "script": "Get-ItemProperty 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*' | Where-Object { $_.DisplayName -like '*Mendix*10.18.4*' } | ForEach-Object { Start-Process -Wait ($_.UninstallString -replace '\"','') -ArgumentList '/VERYSILENT' }"
  },
  "checkver": {
    "url": "https://marketplace.mendix.com/link/studiopro/",
    "jsonpath": "$.version"
  },
  "notes": "Mendix Studio Pro installs to %LOCALAPPDATA%\\Programs\\Mendix\\<version>. Multiple versions can coexist."
}
